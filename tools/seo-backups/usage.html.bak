<body class="has-app-nav font-sans antialiased" style="background-color: #f8f9fa;">

    <header class="main-header account-header pwa-app-header">
        <div class="app-header-shell pwa-header-inner flex flex-row flex-nowrap items-center justify-between w-full gap-3 md:gap-6">
            <div class="pwa-header-leading flex items-center min-w-0 flex-shrink-0 max-w-[60%]">
                <a href="account.html" class="unified-back-btn"><span class="back-arrow">←</span><span class="back-text">Back to Account Hub</span></a>
            </div>
            <nav class="main-nav pwa-desktop-nav" id="pwa-collapse-nav">
                <ul>
                    <li><a href="index.html#features">Features</a></li>
                    <li><a href="index.html#pricing">Pricing</a></li>
