    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <script src="pwa-nav.js"></script>
    <script src="script.js?v=2026.20"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const token = localStorage.getItem('token');
            if (!token) {
                setTimeout(() => { window.location.href = 'account.html'; }, 800);
                return;
            }

            try {
                // 请求数据
                const apiBase = (typeof window !== 'undefined' && window.REPORTIFY_API_BASE) || 'https://api.goreportify.com';
                const res = await fetch(`${apiBase}/api/usage`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                
                if (!res.ok) throw new Error(`Server returned ${res.status}`);
                const data = await res.json();
                
                // 1. 更新分享卡片数据
                const myCode = data.referralCode || 'ERROR';
                const bv = document.getElementById('bonus-val');
                if (bv) {
                    if (data.referralInviteDisplay) {
                        bv.innerText = String(data.referralInviteDisplay.value);
                        bv.title =
                            data.referralInviteDisplay.unit === 'days'
                                ? 'Referral reward: extra membership days (max 5)'
                                : 'Referral reward: +5 if you used a referral link; up to +25 from inviting others';
                    } else {
                        bv.innerText = data.bonusCredits || 0;
                        bv.title = '';
                    }
                }
                
                // 更新链接生成逻辑
                updateShareLinks(myCode);

                console.log("Usage Data:", data);

                // --- 2. 填充计划 ---
                const planCode = (data.plan || 'basic').toLowerCase();
                const planNameEl = document.getElementById('plan-name');
                if (planCode === 'pro') {
                    planNameEl.textContent = 'Professional';
                    planNameEl.style.color = '#e63946';
                    document.getElementById('upgrade-hint').style.display = 'none';
                } else {
                    planNameEl.textContent = 'Basic / Free';
                    document.getElementById('upgrade-hint').style.display = 'block';
                }

                const noteEl = document.getElementById('usage-subscription-note');
                if (noteEl && Array.isArray(data.subscriptionNoteLines) && data.subscriptionNoteLines.length) {
                    noteEl.textContent = '';
                    data.subscriptionNoteLines.forEach(function (line) {
                        const p = document.createElement('p');
                        p.style.margin = '0 0 8px 0';
                        p.textContent = line;
                        noteEl.appendChild(p);
                    });
                    noteEl.style.display = 'block';
                }

                // --- 3. 填充用量数字与卡片 ---
                const used = data.used || 0;
                const limit = data.limit;
                
                // 绑定大字号区域
                document.getElementById('usage-used').textContent = used;

                const progressEl = document.getElementById('usage-progress');
                
                if (limit === '∞' || limit === 'Unlimited' || limit > 9000) {
                    // Pro 会员状态
                    document.getElementById('usage-limit').textContent = "∞";
                    document.getElementById('stat-remaining').textContent = "Unlimited";
                    document.getElementById('stat-remaining').style.fontSize = "1.8rem"; 
                    
                    if (progressEl) {
                        progressEl.style.width = '100%';
                        progressEl.style.background = '#10b981'; // 纯绿色
                    }
                } else {
                    // Basic / Free 状态
                    document.getElementById('usage-limit').textContent = limit;
                    document.getElementById('stat-remaining').textContent = data.remaining !== undefined ? data.remaining : Math.max(0, limit - used);
                    document.getElementById('stat-remaining').style.fontSize = "2.2rem";
                    
                    if (progressEl) {
                        const percent = Math.min(100, (used / limit) * 100);
                        progressEl.style.width = percent + '%';
                        progressEl.style.background = percent > 90 ? '#ef4444' : '#2563eb'; // 快用完变红，否则蓝
                    }
                }

                // --- 4. 填充底部时间卡片 ---
                document.getElementById('stat-daysleft').textContent = data.daysLeft !== undefined ? data.daysLeft : 0;
                document.getElementById('stat-activedays').textContent = data.activeDays || 1;

            } catch (err) {
                console.error("Usage Load Error:", err);
                document.getElementById('plan-name').textContent = "Error loading data";
            }
        });

        // 🟢 全能分享链接生成器
        function updateShareLinks(code) {
            const shareUrl = `${window.location.origin}/?ref=${encodeURIComponent(code)}`;
            const shareText = `I use Reportify AI to generate professional reports in seconds! Sign up to get +5 Free Credits.`;
            const shareTextEncoded = encodeURIComponent(shareText);
            const shareUrlEncoded = encodeURIComponent(shareUrl);

            // 更新输入框
            document.getElementById('share-link-input').value = shareUrl;

            // --- 第一排 ---
            document.getElementById('share-x').href = `https://twitter.com/intent/tweet?text=${shareTextEncoded}&url=${shareUrlEncoded}`;
            document.getElementById('share-wa').href = `https://wa.me/?text=${encodeURIComponent(shareText + ' ' + shareUrl)}`;
            document.getElementById('share-in').href = `https://www.linkedin.com/sharing/share-offsite/?url=${shareUrlEncoded}`;

            // --- 第二排 ---
            document.getElementById('share-fb').href = `https://www.facebook.com/sharer/sharer.php?u=${shareUrlEncoded}`;
            document.getElementById('share-tg').href = `https://t.me/share/url?url=${shareUrlEncoded}&text=${shareTextEncoded}`;
            document.getElementById('share-rd').href = `https://www.reddit.com/submit?url=${shareUrlEncoded}&title=${shareTextEncoded}`;
        }

        // 🟢 优雅的复制功能 (已修复静默 Bug，成功调用全局 Toast)
        function copyLink() {
            const copyText = document.getElementById("share-link-input");
            copyText.select();
            copyText.setSelectionRange(0, 99999); // 手机适配
            
            navigator.clipboard.writeText(copyText.value).then(() => {
                if (window.showToast) {
                    window.showToast("Link Copied to Clipboard!", "success");
                }
            });
        }
    </script>
</body>
</html>
