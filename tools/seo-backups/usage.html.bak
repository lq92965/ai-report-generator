    <div class="container" style="max-width: min(1100px, 96vw); margin: 24px auto 64px; padding: 0 20px;">
        <div style="background: white; border-radius: 24px; padding: clamp(28px, 4vw, 56px); box-shadow: 0 10px 40px rgba(0,0,0,0.06); border: 1px solid #e5e7eb;">
            
            <div style="text-align: center; margin-bottom: 40px;">
                <h1 style="margin: 0 0 10px; color: #333; font-size: 2rem;">Usage Statistics</h1>
                <p style="color: #666;">Current Plan: <span id="plan-name" style="color: #007bff; font-weight: 800; font-size: 1.1rem; text-transform: uppercase;">LOADING...</span></p>
                <div id="upgrade-hint" style="display:none; margin-top:10px;">
                    <a href="subscription.html" class="btn btn-sm btn-outline" style="border-radius:20px; padding:5px 15px; font-size:0.8rem;">Upgrade Plan &rarr;</a>
                </div>
                <div id="usage-subscription-note" style="display:none; margin-top:14px; text-align:left; max-width:560px; margin-left:auto; margin-right:auto; padding:14px 16px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:12px; font-size:0.82rem; line-height:1.55; color:#475569;"></div>
            </div>

            <div style="max-width: 600px; margin: 0 auto 40px; text-align: center;">
                <p style="font-size: 0.9rem; color: #64748b; margin-bottom: 5px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">Used / Total Limit</p>
                <div style="display: flex; align-items: baseline; justify-content: center; gap: 10px;">
                    <span id="usage-used" style="font-size: 4.5rem; font-weight: 900; color: #111827; line-height: 1;">0</span>
                    <span style="font-size: 2rem; font-weight: 700; color: #9ca3af;">/ <span id="usage-limit">21</span></span>
                </div>
                
                <div class="progress-container" style="height: 12px; margin: 25px 0 10px;">
                    <div id="usage-progress" class="progress-bar" style="background: #2563eb; width: 0%;"></div>
                </div>
            </div>

            <hr style="border: 0; border-top: 1px dashed #e2e8f0; margin: 0 0 40px 0;">

            <div class="share-card w-full" id="share-area" style="margin-top: 0; box-shadow: 0 4px 15px rgba(0,0,0,0.03);">
                <div class="share-header">
                    <div class="share-title"><i class="fas fa-gift" style="color: #8b5cf6;"></i> Invite & Earn</div>
                    <div class="share-badge">
                        Your Bonus: <span id="bonus-val">0</span>
                    </div>
                </div>

                <p style="color: #64748b; margin-bottom: 15px; font-size: 0.95rem;">
                    Invite a friend and you BOTH get <strong>+5 Free Reports</strong>! (Pro users get <strong>+1 Pro Day</strong>). Max 5 invites.
                </p>

                <div class="link-box">
                    <input type="text" class="link-input text-xs px-2 tracking-tighter" id="share-link-input" readonly value="Loading your link...">
                    <button type="button" class="btn-copy" onclick="copyLink()">Copy</button>
                </div>

                <div class="flex flex-wrap justify-center gap-2 w-full mt-4 usage-share-grid">
                    <a href="#" id="share-x" target="_blank" class="btn-social btn-x"><i class="fab fa-x-twitter"></i> <span>X</span></a>
                    <a href="#" id="share-wa" target="_blank" class="btn-social btn-wa"><i class="fab fa-whatsapp"></i> <span>WhatsApp</span></a>
                    <a href="#" id="share-in" target="_blank" class="btn-social btn-in"><i class="fab fa-linkedin"></i> <span>LinkedIn</span></a>
                    <a href="#" id="share-fb" target="_blank" class="btn-social btn-fb"><i class="fab fa-facebook"></i> <span>Facebook</span></a>
                    <a href="#" id="share-tg" target="_blank" class="btn-social btn-tg"><i class="fab fa-telegram"></i> <span>Telegram</span></a>
                    <a href="#" id="share-rd" target="_blank" class="btn-social btn-rd"><i class="fab fa-reddit"></i> <span>Reddit</span></a>
                </div>
            </div>

            <div class="w-full max-w-[600px] mx-auto mt-10 space-y-4">
                <div class="w-full relative bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl shadow-sm p-6 min-h-[110px]">
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white shadow-sm flex items-center justify-center" aria-hidden="true">
                        <i class="fas fa-bolt text-yellow-500 text-lg" aria-hidden="true"></i>
                    </div>
                    <div class="absolute inset-0 flex flex-col items-center justify-center text-center pointer-events-none">
                        <div id="stat-remaining" class="text-3xl md:text-4xl font-extrabold text-[#1e293b] leading-none">0</div>
                        <div class="mt-1 text-sm md:text-base font-semibold text-[#64748b]">Remaining</div>
                    </div>
                </div>

                <div class="w-full relative bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl shadow-sm p-6 min-h-[110px]">
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white shadow-sm flex items-center justify-center" aria-hidden="true">
                        <i class="fas fa-hourglass-half text-emerald-500 text-lg" aria-hidden="true"></i>
                    </div>
                    <div class="absolute inset-0 flex flex-col items-center justify-center text-center pointer-events-none">
                        <div id="stat-daysleft" class="text-3xl md:text-4xl font-extrabold text-[#1e293b] leading-none">0</div>
                        <div class="mt-1 text-sm md:text-base font-semibold text-[#64748b]">Days Left</div>
                    </div>
                </div>

                <div class="w-full relative bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl shadow-sm p-6 min-h-[110px]">
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white shadow-sm flex items-center justify-center" aria-hidden="true">
                        <i class="far fa-calendar-check text-[#2563eb] text-lg" aria-hidden="true"></i>
                    </div>
                    <div class="absolute inset-0 flex flex-col items-center justify-center text-center pointer-events-none">
                        <div id="stat-activedays" class="text-3xl md:text-4xl font-extrabold text-[#1e293b] leading-none">1</div>
                        <div class="mt-1 text-sm md:text-base font-semibold text-[#64748b]">Active Days</div>
                    </div>
                </div>
            </div>

        </div>
    </div>

